# Postgres — Hetzner Managed (EU, Nürnberg) per HAC-10 stack pick
DATABASE_URL=postgres://user:pass@host:5432/closelyst

# Messaging provider switch
#   fake     — in-memory, default for dev/demo (no env required)
#   meta     — direct WhatsApp Cloud API (board chose this path on HAC-9)
#   360dialog — BSP-mediated WABA (HAC-10 originally approved; not currently used)
MESSAGING_PROVIDER=fake

# Meta WhatsApp Cloud API (direct, per board decision on HAC-9 / HAC-17)
# WABA = WhatsApp Business Account.
# META_WABA_ID=                      # e.g. 1298216662200433 (per board 2026-04-20)
# META_PHONE_NUMBER_ID=              # comes from Meta after phone-number registration
# META_ACCESS_TOKEN=                 # System User token (long-lived); never commit
# META_WEBHOOK_VERIFY_TOKEN=         # arbitrary string; must match Meta webhook config
# META_APP_SECRET=                   # for HMAC signature verification on inbound

# 360dialog BSP path (kept for reference; flip MESSAGING_PROVIDER to use)
# THREE_SIXTY_DIALOG_API_KEY=
# THREE_SIXTY_DIALOG_WEBHOOK_SECRET=

# SMS fallback (sms77, EU, per HAC-10)
# SMS77_API_KEY=
# SMS77_WEBHOOK_SECRET=
